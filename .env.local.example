# ============================================================
# HATE Intelligence — environment variables
# Copy this file to .env.local and fill each value.
# Never commit .env.local — it's in .gitignore.
# ============================================================

# --- Supabase ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# From dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# After running `stripe listen` (CLI) or creating a webhook endpoint:
# Webhook signing secret (starts with whsec_...)
STRIPE_WEBHOOK_SECRET=

# Price IDs from your two Stripe products (starts with price_...)
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=

# --- Anthropic ---
# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- App ---
# Local: http://localhost:3000  |  Prod: https://app.haterz.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000
