# ============================================================
# HATE Intelligence — environment variables
# Copy this file to .env.local and fill each value.
# Never commit .env.local — it's in .gitignore.
# ============================================================

# --- Supabase ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# From dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# After running `stripe listen` (CLI) or creating a webhook endpoint:
# Webhook signing secret (starts with whsec_...)
STRIPE_WEBHOOK_SECRET=

# --- Stripe price IDs (multi-product entitlement model) ---
# Each Stripe price must carry metadata of the form:
#   entitlements = "<product>:<tier>[,<product>:<tier>...]"
# The webhook reads that metadata to create entitlement rows.
#
# Standalone products ($29 starter / $79 pro):
NEXT_PUBLIC_STRIPE_PRICE_INTELLIGENCE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_INTELLIGENCE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_MEETINGS_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_MEETINGS_PRO=
# Everything — both products in one price ($45 starter / $119 pro, ~25% off):
NEXT_PUBLIC_STRIPE_PRICE_EVERYTHING_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_EVERYTHING_PRO=

# --- Anthropic ---
# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- App ---
# Local: http://localhost:3000  |  Prod: https://app.haterz.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000
